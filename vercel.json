{
  "version": 2,
  "functions": {
    "api/discovery.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/discovery",
      "dest": "/api/discovery.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
